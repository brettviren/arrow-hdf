@PACKAGE_INIT@

# arrow_hdf: generic Arrow <-> HDF5 serialization.
# arrow_hdf::arrow_hdf_core  — pure Address/Hierarchy (no external deps)
# arrow_hdf::arrow_hdf       — the HDF5 serializer (Arrow + HDF5), if built

include(CMakeFindDependencyMacro)
set(ARROW_HDF_HAVE_HDF5 @ARROW_HDF_HAVE_HDF5@)
if(ARROW_HDF_HAVE_HDF5)
  find_dependency(Arrow)
  find_dependency(HDF5 COMPONENTS C)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/arrow_hdfTargets.cmake")
